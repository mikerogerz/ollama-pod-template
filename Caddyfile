:8080 {
	# Health check endpoint (no auth)
	@health path /health
	handle @health {
		respond `{"status":"healthy","service":"ollama-caddy"}` 200
		header Content-Type application/json
	}
	
	# All other endpoints require authentication
	handle {
		# Check if Authorization header exists
		@no_key {
			not header Authorization *
		}
		handle @no_key {
			respond `{"error":"Unauthorized","message":"Missing Authorization header"}` 401
			header Content-Type application/json
		}
		
		# Check for valid Bearer token (replaced at runtime with actual token)
		@valid_token header Authorization "Bearer YOUR_API_KEY"
		handle @valid_token {
			reverse_proxy 127.0.0.1:11434 {
				header_up Host {host}
				header_up X-Real-IP {remote_host}
			}
		}
		
		# If no valid key matched, return 403
		respond `{"error":"Forbidden","message":"Invalid API key"}` 403
		header Content-Type application/json
	}
	
	# Security headers
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		X-XSS-Protection "1; mode=block"
		-Server
	}
	
	log {
		output stdout
		format console
	}
}